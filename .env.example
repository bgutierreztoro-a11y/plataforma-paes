# Clave pública de PostHog. Opcional: si no está definida, la app funciona
# igual y los 6 eventos de analítica solo se loguean a consola en desarrollo.
NEXT_PUBLIC_POSTHOG_KEY=

# Host de PostHog (opcional). Por defecto: https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=

# Neon Postgres. Son dos conexiones con dos roles distintos a propósito.
# Ambas son secretas: van en .env.local (ignorado por git), nunca acá.
# Formato: postgresql://usuario:clave@host/base?sslmode=require

# Rol restringido de la app. Lo usa lib/datos/ y todo lo que corre en Vercel.
# Puede leer y escribir filas, pero NO crear ni alterar tablas, y no puede
# hacer UPDATE ni DELETE sobre entitlements_auditoria. Usa la cadena con
# pooler (el host lleva "-pooler"): las funciones serverless abren y cierran
# conexiones todo el tiempo.
DATABASE_URL=

# Rol dueño. Lo usa solo `npm run migrar`, nunca la app ni el deploy.
# Usa la cadena directa, SIN "-pooler": el pooler trabaja en modo transacción
# y el DDL se lleva mal con eso.
DATABASE_URL_MIGRACIONES=

# Clerk. A diferencia de PostHog, estas NO son opcionales: ClerkProvider lanza
# si falta la publishable key, y como las lecciones se prerenderizan, el build
# entero falla. Las dos primeras salen del dashboard, en API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Secreto de firma del webhook, distinto de la secret key. Aparece al crear el
# endpoint en el dashboard (Webhooks → el endpoint → Signing Secret). Lo usa
# verifyWebhook() en app/api/webhooks/clerk/route.ts; sin él, ningún evento se
# acepta. Empieza con "whsec_".
CLERK_WEBHOOK_SIGNING_SECRET=
